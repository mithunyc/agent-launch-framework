{
  "schema_version": "0.1.0",
  "job_id": "world-class-reviewer.variance-gate.local",
  "agent_pack": {
    "id": "world-class-reviewer",
    "version": "0.1.0"
  },
  "task": {
    "kind": "variance-gate",
    "prompt": "Run the full clean-room behavior gate three times and compare semantic scores, case statuses, and bounded answer fingerprint drift before plugin, cloud, mobile, or provider-adapter promotion.",
    "inputs": [
      "agent-packs/world-class-reviewer/agent.yaml",
      "agent-packs/world-class-reviewer/evals/cases"
    ]
  },
  "runtime": {
    "adapter": "adapters/codex",
    "surface": "codex-cli-exec",
    "sandbox": "read-only",
    "timeout_seconds": 600,
    "clean_room": true,
    "isolated_codex_home": true,
    "codex_exec_flags": [
      "--ignore-user-config",
      "--ignore-rules",
      "--disable",
      "plugins"
    ]
  },
  "autonomy_tier": "A0-read-only",
  "policy": {
    "approval_required": false,
    "allowed_actions": [
      "validate-pack",
      "static-eval",
      "codex-behavior-eval",
      "semantic-eval",
      "second-opinion-eval",
      "variance-eval",
      "write-local-receipt"
    ],
    "blocked_actions": [
      "global-install",
      "write-production-data",
      "deploy",
      "self-promote-memory",
      "self-modify-skill"
    ]
  },
  "workspace": {
    "strategy": "disposable"
  },
  "eval_gate": {
    "required": true,
    "cases": [
      "all"
    ],
    "semantic_required": true,
    "second_opinion_required": true
  },
  "variance_gate": {
    "required": true,
    "runs": 3,
    "max_answer_fingerprint_drift": 0.65,
    "max_structural_count_drift": 5,
    "semantic_score_drift_allowed": 0,
    "case_status_drift_allowed": 0,
    "second_opinion_score_drift_allowed": 0
  },
  "receipt": {
    "required": true,
    "target": "agent-packs/world-class-reviewer/receipts/runs"
  },
  "created_at": "2026-06-20T00:00:00Z"
}
